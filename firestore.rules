rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 1. APP STATE (กลุ่มข้อมูลระบบพื้นฐาน)
    // ==========================================
    match /app_state/{docId} {
      // อ่านและอัปเดตได้ทุกคน แต่ห้าม "ลบ" document ทิ้งเด็ดขาดเพื่อป้องกันข้อมูลระบบหาย
      allow read, create: if true;
      allow update: if true;
      allow delete: if false; 
    }
    
    // ==========================================
    // 2. TRANSACTION LOGS (ประวัติการทำธุรกรรม)
    // ==========================================
    match /transaction_logs/{logId} {
      allow read: if true;
      
      // การสร้าง/แก้ไข ต้องมีข้อมูลที่จำเป็นและชนิดข้อมูลถูกต้อง
      allow create, update: if 
        request.resource.data.keys().hasAll(['formType', 'requester', 'totalPrice', 'createdAt']) &&
        request.resource.data.formType is string &&
        request.resource.data.requester is string &&
        request.resource.data.totalPrice is number;
        
      allow delete: if true; // ระบบมีปุ่มลบให้ใช้งาน
    }
    
    // ==========================================
    // 3. CITIZENS (ข้อมูลประชาชน)
    // ==========================================
    match /citizens/{citizenId} {
      allow read, delete: if true;
      
      // บังคับว่าต้องมีชื่อ
      allow create, update: if 
        request.resource.data.keys().hasAny(['name']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0;
    }
    
    // ==========================================
    // 4. LOAN CONTRACTS & TRANSACTIONS (ระบบเงินกู้)
    // ==========================================
    match /loan_contracts/{contractId} {
      allow read, delete: if true;
      
      // บังคับโครงสร้างพื้นฐานของสัญญาเงินกู้
      allow create, update: if 
        request.resource.data.keys().hasAll(['citizenName', 'loanAmount', 'interestRate']) &&
        request.resource.data.loanAmount is number &&
        request.resource.data.interestRate is number;
    }
    
    match /transactions/{txId} {
      allow read, delete: if true;
      // บังคับโครงสร้างการจ่ายเงิน
      allow create, update: if 
        request.resource.data.keys().hasAll(['contractId', 'amount']) &&
        request.resource.data.amount is number;
    }
    
    // ==========================================
    // 5. OTHERS (คอลเลกชันอื่นๆ ที่เหลือ)
    // ==========================================
    match /{document=**} {
      // เปิดให้อ่านและเขียนได้ทั้งหมด (เนื่องจากไม่ได้บังคับ Login)
      allow read, write: if true;
    }
    
  }
}

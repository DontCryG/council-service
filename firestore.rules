rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core data: Anyone can read, only Auth users can write/update/delete
    match /app_state/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /system/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /loan_contracts/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /transactions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Form submissions: Public can create, but only Auth can update/delete/read
    match /transaction_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    match /transactionImages/{imgId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    
    // Citizens: Public can read and create, Auth can manage
    match /citizens/{citizenId} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Default fallback (protect everything else)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

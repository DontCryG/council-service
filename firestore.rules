rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // ฟังก์ชันตรวจสอบพื้นฐาน
    // ==========================================
    function isAuthenticated() {
      return request.auth != null;
    }

    // ==========================================
    // 1. APP STATE & SYSTEM (ระบบพื้นฐาน)
    // ==========================================
    match /app_state/{docId} {
      // 🔒 ให้คนทั่วไปอ่านรายชื่อ Admin ได้ แต่ ห้ามเขียน/แก้ไขเด็ดขาด ป้องกัน Privilege Escalation
      allow read: if true;
      allow write: if false; 
    }
    
    match /system/{docId} {
      // ⚠️ การปิด-เปิดระบบใช้ Client-side Password ("wiptownadmin")
      // บังคับให้แก้ไขได้แค่ฟิลด์ isClosed เท่านั้น ป้องกันการพังระบบ
      allow read: if true;
      allow update: if request.resource.data.keys().hasOnly(['isClosed']) 
                    && request.resource.data.isClosed is bool;
      allow create, delete: if false;
    }
    
    // ==========================================
    // 2. TRANSACTION LOGS & IMAGES (ประวัติและรูปภาพ)
    // ==========================================
    match /transaction_logs/{logId} {
      allow read: if true;
      // 🔒 ให้คนทั่วไปสร้าง Log ได้เมื่อส่งฟอร์ม แต่ห้ามแก้ไขหรือลบ
      allow create: if true;
      allow update: if isAuthenticated(); // ให้ Admin เท่านั้นที่อัปเดตได้ (เช่น อนุมัติ/ปฏิเสธ)
      allow delete: if false; // 🛑 ประวัติห้ามลบเด็ดขาด
    }

    match /transactionImages/{imageId} {
      allow read, create: if true;
      allow update, delete: if isAuthenticated();
    }
    
    // ==========================================
    // 3. CITIZENS (ข้อมูลประชาชน)
    // ==========================================
    match /citizens/{citizenId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['name']) &&
                    request.resource.data.name is string;
      allow update, delete: if isAuthenticated(); // 🔒 เฉพาะ Admin ที่แก้ชื่อ/ลบข้อมูลคนได้
    }
    
    // ==========================================
    // 4. LOAN CONTRACTS & TRANSACTIONS (ระบบเงินกู้)
    // ==========================================
    match /loan_contracts/{contractId} {
      allow read: if true; // ให้อ่านได้เพื่อเอาไปค้นหาสถานะ
      allow create, update, delete: if isAuthenticated(); // 🔒 ธุรกรรมการเงินต้องเป็น Admin เท่านั้นที่จัดการได้
    }
    
    match /transactions/{txId} {
      allow read: if true; 
      allow create, update, delete: if isAuthenticated(); // 🔒 การจ่ายเงินต้องเป็น Admin เท่านั้น
    }
    
    // 🛑 ปิด Wildcard ทิ้ง! ไม่อนุญาตให้เข้าถึง Collection อื่นๆ ที่ไม่ได้ระบุ
    // match /{document=**} { allow read, write: if true; } // ลบทิ้งแล้ว
  }
}

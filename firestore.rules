rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // System Settings (Open/Close portal)
    match /system/{docId} {
      allow read, write: if true;
    }

    // Duty History: Anyone logged in can read, only admin can write
    match /dutyHistory/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Council Members: Anyone logged in can read, only admin can write
    match /councilMembers/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
    
    // Transaction Logs: Anyone logged in can read, public can create, admin can edit
    match /transaction_logs/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null && request.auth.token.role == 'admin';
    }
  }
}

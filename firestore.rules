rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // เนื่องจากระบบมีการใช้ Custom Auth ผ่าน localStorage ทำให้ request.auth เป็น null
    // จึงต้องเปิดสิทธิ์ให้อ่าน/เขียนได้เพื่อให้ระบบทำงานได้ตามปกติ
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
